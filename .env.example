# Omni 统一平台 · 环境变量配置
# 复制此文件为 .env，填入实际值

# 数据库（不填则使用 SQLite）
# 开发：留空或填 sqlite:///./omni.db
# 生产：postgresql://user:password@host:5432/dbname
DATABASE_URL=

# 会话密钥（生产必改，至少 32 位随机字符串）
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# 允许的跨域来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
